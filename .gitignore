# Minecraft Server — .gitignore

# Sensitive / Private Data
ops.json
whitelist.json
banned-players.json
banned-ips.json
usercache.json
server.properties
.console_history

# Plugin secrets & machine IDs
plugins/ServerTap/config.yml

# Logs & Cache
logs/
cache/
versions/
libraries/

# Generated / Runtime
plugins/.paper-remapped/
plugins/bStats/
plugins/spark/

# Server JAR (large binary, not plugin JARs)
paper.jar

# Bundled runtime binaries (too large for GitHub)
jre/
overlay/node.exe

# Dev / IDE
.vscode/
mabel-ricefarm/
backup/
bug_farm.txt

# Node modules
node_modules/
**/node_modules/

# OS files
Thumbs.db
desktop.ini
.DS_Store

# Release artifacts (uploaded via gh release)
release/
